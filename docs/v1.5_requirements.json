          "input": {
            "section_artifacts": "array of per-section artifacts",
            "memory_section": "MemoryOutput",
            "recap_section": "RecapOutput"
          },
          "output": "presentation.json matching v1.3 schema",
          "operations": [
            "1. Order sections: intro, summary, content[], example, memory, recap",
            "2. Assign sequential section_ids (1, 2, 3...)",
            "3. FOR EACH section artifact:",
            "   3a. Build avatar_layout from blueprint.avatar_*",
            "   3b. Copy narration object directly",
            "   3c. Build visual_beats from visuals output",
            "   3d. Merge display_directives into segments",
            "   3e. Attach render_spec (manim_scene_spec or video_prompts)",
            "4. Add global metadata (spec_version, avatar_global, etc.)",
            "5. Validate against v1.3 schema"
          ],
          "field_mapping": {
            "blueprint.section_type": "section.section_type",
            "blueprint.title": "section.title",
            "blueprint.suggested_renderer": "section.renderer",
            "blueprint.avatar_visibility": "section.avatar_layout.visibility",
            "blueprint.avatar_position": "section.avatar_layout.position",
            "narration.full_text": "section.narration.full_text",
            "narration.segments[].segment_id": "section.narration.segments[].segment_id",
            "narration.segments[].text": "section.narration.segments[].text",
            "narration.segments[].duration_seconds": "section.narration.segments[].duration_seconds",
            "narration.segments[].gesture_hint": "section.narration.segments[].gesture_hint",
            "visuals.segment_enrichments[].visual_content": "MERGE INTO section.narration.segments[].visual_content",
            "visuals.segment_enrichments[].display_directives": "MERGE INTO section.narration.segments[].display_directives",
            "visuals.visual_beats": "section.visual_beats (copy directly - already matches schema)",
            "render_spec.manim_scene_spec": "section.manim_scene_spec",
            "render_spec.video_prompts": "section.video_prompts",
            "render_spec.remotion_scene_spec": "section.remotion_scene_spec"
          },
          "merge_algorithm": [
            "1. Create section shell from blueprint",
            "2. Copy narration.full_text and narration.segments[]",
            "3. FOR EACH segment in narration.segments:",
            "   - Find matching segment_enrichment by segment_id",
            "   - Add visual_content from enrichment",
            "   - Add display_directives from enrichment",
            "4. Copy visual_beats array directly (already schema-compliant)",
            "5. Attach render_spec based on renderer type",
            "6. Validate merged section against v1.3 schema"
          ]
        },

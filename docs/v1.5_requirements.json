          "sync_rules": [
            "1. Each visual_beat.segment_id references narration segment_id",
            "2. display_directives (in segments) control what shows during each segment",
            "3. TTS pass updates segment.duration_seconds with actual audio length",
            "4. Player reads segment.duration_seconds for playback timing",
            "5. Player reads segment.display_directives to show/hide layers"
          ],
          "timing_flow": {
            "pre_tts": "LLM estimates duration based on word count (130 WPM)",
            "post_tts": "Narakeet generates audio, mutagen measures actual duration",
            "final": "Segments have actual duration_seconds from audio"
          },
          "critical_invariants": [
            "visual_beat[i].segment_id must exist in narration.segments",
            "Every segment must have display_directives after merge",
            "sum(segment.duration_seconds) = section total duration"
          ]
        }

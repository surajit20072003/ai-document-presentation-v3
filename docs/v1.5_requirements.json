          "flow": [
            "1. SmartChunker → topics.json",
            "2. SectionPlanner(topics) → section_blueprints[]",
            "3. FOR EACH section_blueprint:",
            "   3a. NarrationWriter(blueprint) → narration",
            "   3b. VisualSpecArtist(blueprint, narration) → visuals",
            "   3c. IF renderer != 'none': RendererSpecAgent(visuals) → render_spec",
            "4. MemoryFlashcardAgent(full_markdown) → memory_section",
            "5. RecapSceneAgent(full_markdown, memory.flashcards) → recap_section",
            "6. MergeStep(all_outputs) → presentation.json",
            "7. TTS(presentation) → audio files + updated durations",
            "8. RendererExecutor(presentation) → video files"
          ],
          "state_management": {
            "per_section_artifacts": {
              "blueprint": "SectionBlueprint",
              "narration": "NarrationOutput",
              "visuals": "VisualOutput",
              "render_spec": "RenderSpec (optional)"
            },
            "global_artifacts": {

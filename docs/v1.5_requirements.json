  "guardrails": {
    "G1": {
      "title": "Presentation Schema Immutability",
      "description": "presentation.json schema (v1.3) MUST NOT change",
      "enforcement": "Validate all merged output against schemas/presentation_v1.3.schema.json",
      "on_violation": "HARD FAIL - pipeline aborts"
    },
    "G2": {
      "title": "Player Code Freeze",
      "description": "player.js and related frontend files MUST NOT change",
      "enforcement": "No files in player/ directory modified during V1.5 implementation",
      "on_violation": "Code review rejection"
    },
    "G3": {
      "title": "Two-Channel Separation",
      "description": "Narration text (TTS) and visual_content (screen) are separate",
      "enforcement": "Validation checks narration.segments[].text != visual_content fields",
      "on_violation": "Semantic validation failure"
    },
    "G4": {
      "title": "Display Directive Mutual Exclusion",
      "description": "text_layer and visual_layer cannot both be 'show'",
      "enforcement": "Validation on every segment",
      "on_violation": "Semantic validation failure"
    },
    "G5": {
      "title": "Renderer Spec Required for Non-None Renderers",
      "description": "If renderer != 'none', must have corresponding spec",
      "enforcement": {
        "manim": "manim_scene_spec with objects and animation_sequence",
        "video": "video_prompts with 300+ word prompts",
        "remotion": "remotion_scene_spec"
      },
      "on_violation": "Render failure"
    },
    "G6": {
      "title": "Idempotent Agent Retries",
      "description": "Each agent can be retried independently without affecting others",
      "enforcement": "Agent outputs are pure functions of inputs",
      "on_violation": "Architecture violation"
    }
  },

  "presentation_json_field_preservation": {
    "description": "Exact mapping of V1.5 agent outputs to presentation.json fields",
    "root_fields": {
      "spec_version": "set to 'v1.5' (player ignores this, uses v1.3 schema)",
      "presentation_id": "generated UUID",
      "subject": "from input",
      "grade": "from input",
      "chapter_title": "from first topic title",
      "avatar_global": {
        "style": "teacher",
        "default_position": "right",
        "default_width_percent": 30,
        "gesture_enabled": true
      }
    },
    "section_fields": {
      "section_id": "sequential integer (1, 2, 3...)",
      "section_type": "from SectionPlanner",
      "title": "from SectionPlanner",
      "renderer": "from SectionPlanner (enforced by merge step)",
      "avatar_layout": {
        "visibility": "from SectionPlanner.avatar_visibility",
        "mode": "derived from section_type",
        "position": "from SectionPlanner.avatar_position",
        "width_percent": "default 30, intro 50+"
      },
      "narration": {
        "full_text": "from NarrationWriter",
        "segments": {
          "segment_id": "from NarrationWriter",
          "text": "from NarrationWriter (TTS only)",
          "duration_seconds": "from TTS pass (actual audio length)",
          "gesture_hint": "from NarrationWriter (optional)",
          "visual_content": "from VisualSpecArtist",
          "display_directives": "from VisualSpecArtist"
        }
      },
      "visual_beats": {
        "source": "VisualSpecArtist",
        "required_fields": ["beat_id (string)", "segment_id (number)", "visual_beat_type (string)", "description (string 10+ chars)"],
        "optional_fields": ["symbolic_overlay"]
      },
      "manim_scene_spec": "from RendererSpecAgent (if renderer=manim)",
      "video_prompts": "from RendererSpecAgent (if renderer=video)",
      "remotion_scene_spec": "from RendererSpecAgent (if renderer=remotion)"
    }
  },

  "narration_sync_architecture": {
    "description": "How narration timing syncs with visuals",
    "flow": [
      "1. NarrationWriter outputs segments with estimated duration (word_count / 130 * 60)",
      "2. VisualSpecArtist outputs visual_beats with segment_id references",
      "3. VisualSpecArtist outputs segment_enrichments with visual_content + display_directives",

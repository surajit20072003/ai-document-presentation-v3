  {
  "spec_version": "v1.5",
  "title": "Split Agent Architecture - Single Source of Truth",
  "description": "Refactored pipeline with small, focused agents replacing mega-Directors while preserving presentation.json schema",
  "created": "2025-12-23",
  "status": "phase_4_complete",

  "guiding_principles": {
    "P1": "Presentation layer (player.js, presentation.json schema) MUST NOT change",
    "P2": "Only LLM layer and orchestration change - display will display",
    "P3": "Each agent has ONE focused responsibility with small output schema",
    "P4": "Fail-fast with targeted retries per agent",
    "P5": "Deterministic merge step assembles agent outputs into presentation.json",
    "P6": "All field names in final output match existing v1.3 schema exactly",
    "P7_CONTENT_INTEGRITY": "Display ONLY content from source document - nothing added, nothing removed. Agents structure/format source content but do NOT invent facts or add placeholder data."
  },

  "architecture_comparison": {
    "v1.4_current": {
      "agents": 3,
      "flow": "SmartChunker → ContentDirector (8 sections) → RecapDirector (2 sections) → Merge → Renderers → TTS",
      "problems": [
        "ContentDirector emits 50+ tightly coupled fields in one call",
        "High retry cascades - one bad field fails entire output",
        "LLM struggles with complex nested schema",
        "Different section types have different requirements but same prompt"
      ]
    },
    "v1.5_proposed": {
      "agents": 6,
      "flow": "Chunker → SectionPlanner → NarrationWriter → VisualSpecArtist → RendererSpecAgent → Merge → TTS",
      "benefits": [
        "Each agent focuses on 5-10 fields max",
        "Retry scope is per-agent, not entire presentation",
        "Matches proven V3 pipeline architecture",
        "Easier to debug and tune individual agents"
      ]
    }
  },


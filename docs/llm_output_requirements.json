{
    "version": "1.2",
    "role": "LLM Director",
    "description": "Authoritative contract for 3-pass educational video pipeline. Pass 0: Chunker, Pass 1: Director, Pass 2: Renderers (Manim/Remotion/Video).",
    "architecture": {
        "pass_0_chunker": {
            "purpose": "Pure preprocessing - split markdown into teaching chunks",
            "model": "gemini-2.5-flash",
            "input": "Raw textbook Markdown",
            "output": "Chunked JSON with chunk_id, title, content, chunk_type"
        },
        "pass_1_director": {
            "purpose": "Pedagogy, structure, timing, renderer decisions",
            "model": "gemini-2.5-pro",
            "input": "Chunked JSON + subject metadata",
            "output": "presentation.json with sections, narration, visual beats (NO renderer code)"
        },
        "pass_2_renderers": {
            "manim": {
                "purpose": "Math/physics visuals - equations, geometry, graphs",
                "model": "anthropic/claude-3.5-sonnet",
                "input": "Section with visual beats",
                "output": "manim_scene_spec JSON"
            },
            "remotion": {
                "purpose": "Motion graphics - summaries, quizzes, formula presentation",
                "model": "anthropic/claude-3.5-sonnet",
                "input": "Section with visual beats",
                "output": "remotion_scene_spec JSON"
            },
            "video": {
                "purpose": "Biology, chemistry, recap storytelling - WAN/diffusion prompts",
                "model": "gemini-2.5-pro",
                "input": "Section with visual beats",
                "output": "Video prompt JSON"
            }
        }
    },
    "global_principles": {
        "llm_is_director": true,
        "renderers_are_executors": true,
        "player_is_dumb": true,
        "no_fallbacks_allowed": true,
        "fail_fast_on_quality_violation": true,
        "separation_of_concerns": true
    },
    "chunker_output_schema": {
        "chunks": [
            {
                "chunk_id": "number",
                "title": "string",
                "content": "string (preserved exactly)",
                "chunk_type": "concept | example | exercise | summary"
            }
        ]
    },
    "display_fitness_rules": {
        "max_text_lines_on_screen": 4,
        "max_words_per_line": 12,
        "no_simultaneous_dense_text_and_complex_visual": true,
        "if_text_exceeds_limits": "split_into_additional_segments"
    },
    "symbolic_overlay_rule": {
        "during_complex_visuals_allow_only": [
            "math symbols (a =, F =)",
            "equation fragments",
            "variable labels",
            "step labels"
        ],
        "max_words": 4,
        "no_sentences": true
    },
    "pedagogical_sequence_rule": {
        "content_sections": "explain_with_text_then_visualize",
        "example_sections": "visualize_step_by_step_with_minimal_text",
        "never_show_full_text_and_complex_visual_simultaneously": true
    },
    "section_types": [
        "intro",
        "summary",
        "content",
        "example",
        "quiz",
        "memory",
        "recap"
    ],
    "renderer_decision_rules": {
        "manim": [
            "math",
            "vectors",
            "geometry",
            "graphs",
            "numerical_physics_examples",
            "derivations"
        ],
        "remotion": [
            "intro_motion_graphics",
            "summary_animations",
            "quiz_displays",
            "formula_reveals"
        ],
        "video": [
            "biology_processes",
            "physical_phenomena",
            "chemistry_reactions",
            "conceptual_fields",
            "recap_storytelling"
        ]
    },
    "avatar_gesture_rules": {
        "gesture_scope": "semantic_only",
        "allowed_gestures": [
            "point_left",
            "point_right",
            "point_center",
            "open_palms",
            "nod",
            "emphasize",
            "idle"
        ],
        "gesture_binding": "per_narration_segment",
        "no_engine_specific_names": true
    },
    "section_structure": {
        "common_fields": [
            "section_id",
            "section_type",
            "title",
            "renderer",
            "renderer_reasoning",
            "layout",
            "narration",
            "narration_segments"
        ]
    },
    "narration_segments": {
        "required_fields": [
            "id",
            "text",
            "duration_seconds"
        ],
        "optional_fields": [
            "gesture_hint"
        ]
    },
    "gesture_hint": {
        "type": "one_of_allowed_gestures",
        "intent": "string"
    },
    "content_section_rules": {
        "minimum_narration_words": 150,
        "maximum_narration_words": 250,
        "must_have_visual_beats": true
    },
    "visual_beat_structure": {
        "note": "Director generates descriptive beats; Renderers convert to specs",
        "director_output": {
            "segment_id": "matches narration_segment.id",
            "scene_setup": "initial state of the scene (descriptive)",
            "objects_and_properties": "all objects, positions, colors, sizes (descriptive)",
            "motion_sequence": "step-by-step animation description",
            "labels_and_text": "all visible labels and symbols",
            "pedagogical_focus": "goal of this beat",
            "duration_seconds": "float"
        },
        "renderer_adds": {
            "manim_scene_spec": "Added by Manim renderer",
            "remotion_scene_spec": "Added by Remotion renderer",
            "video_prompt": "Added by Video renderer"
        }
    },
    "manim_scene_spec": {
        "coordinate_system": {
            "type": "cartesian",
            "origin": [0, 0],
            "scale": 1.0
        },
        "objects": [
            {
                "id": "string",
                "type": "equation | shape | graph | vector | point | label",
                "position": [0, 0],
                "properties": {}
            }
        ],
        "animation_sequence": [
            {
                "action": "appear | draw | show_equation | highlight | transform | move | fade_out | wait",
                "target": "object_id",
                "duration": "number",
                "target_latex_part": "string (optional for partial highlight)",
                "color": "string (optional)"
            }
        ]
    },
    "remotion_scene_spec": {
        "fps": 30,
        "duration_frames": "number",
        "elements": [
            {
                "id": "string",
                "type": "text | shape | icon | image",
                "content": "string",
                "position": {"x": "number", "y": "number"},
                "style": {},
                "animation": {
                    "enter": "fade_in | slide_in | scale_up",
                    "exit": "fade_out | slide_out | scale_down",
                    "enter_frame": "number",
                    "exit_frame": "number"
                }
            }
        ],
        "background": {"color": "string"}
    },
    "video_prompt_spec": {
        "prompt": "string - literal video description",
        "duration_seconds": "number",
        "style": "educational | realistic | animated"
    },
    "example_section_rules": {
        "must_have_example_steps": true,
        "example_steps": [
            "identify_known_quantities",
            "draw_geometry",
            "apply_formula",
            "solve_stepwise",
            "state_conclusion"
        ],
        "renderer": "manim",
        "each_step_requires_visual_beat": true
    },
    "quiz_handling_rules": {
        "one_question_per_section": true,
        "answer_hidden_initially": true,
        "solution_revealed_stepwise": true,
        "visual_style": "flash_card_or_blackboard"
    },
    "memory_section_rules": {
        "format": "flashcards",
        "flashcard_limit": 5,
        "acronym_based": true
    },
    "recap_section_rules": {
        "renderer": "video",
        "scene_count": 5,
        "scene_narration_words_range": [60, 100],
        "storytelling_mode": true,
        "no_text_slides": true,
        "mental_movie_goal": true
    },
    "validation_rules": {
        "hard_fail_conditions": [
            "content_or_example_narration_below_minimum",
            "missing_visual_beats",
            "example_without_step_visualization",
            "formula_mentioned_but_not_visualized",
            "vague_visual_language_detected",
            "manim_section_without_scene_spec",
            "remotion_section_without_scene_spec",
            "video_section_without_prompt"
        ],
        "soft_warn_conditions": [
            "intro_summary_memory_recap_length_variation"
        ]
    },
    "analytics": {
        "track_per_phase": true,
        "metrics": [
            "duration_seconds",
            "input_tokens",
            "output_tokens",
            "cost_usd",
            "status"
        ],
        "phases": [
            "chunker",
            "director",
            "manim_renderer",
            "remotion_renderer",
            "video_renderer",
            "audio_generation",
            "video_compilation"
        ]
    },
    "traceability": {
        "generation_trace_required": true,
        "render_prompts_logged": true,
        "renderer_decisions_logged": true,
        "validation_results_logged": true,
        "analytics_saved": true
    }
}
